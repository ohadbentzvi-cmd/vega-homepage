---
const navLinks = [
  { label: 'דף הבית', href: '#hero' },
  { label: 'אודות', href: '#about' },
  { label: 'תחומי פעילות', href: '#services-1' },
  { label: 'דרושים', href: '#jobs' },
  { label: 'יצירת קשר', href: '#contact' },
];
---

<footer class="footer">
  <div class="footer__main">
    <div class="container">
    <div class="footer__inner">
      <a href="#hero" class="footer__logo-link" aria-label="VEGA Holdings">
        <img src="/logos/VEGA-LOGO-white.png" alt="VEGA Holdings" class="footer__logo" />
      </a>

      <ul class="footer__nav">
        {navLinks.map(link => (
          <li><a href={link.href} class="footer__nav-link">{link.label}</a></li>
        ))}
      </ul>

      <div class="footer__contact">
        <a href="tel:050-000-0000" class="footer__contact-item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 9.12a16 16 0 0 0 6 6l1.48-1.48a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16z"/></svg>
          050-000 00 00
        </a>
        <a href="#contact" class="footer__contact-item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          כתובת עיר רחוב מס
        </a>
      </div>
    </div>
    </div>
  </div>

  <div class="footer__bottom">
    <div class="container">
      <p class="footer__copy">© {new Date().getFullYear()} VEGA Holdings. כל הזכויות שמורות.</p>
    </div>
  </div>
</footer>

<style>
.footer {
  background: var(--color-dark);
  color: rgba(255,255,255,0.75);
}

.footer__main {
  padding: 0;
  border-bottom: 1px solid rgba(255,255,255,0.08);
}

.footer__inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 80px;
  gap: 24px;
}

.footer__logo-link {
  display: flex;
  align-items: center;
  flex-shrink: 0;
}

.footer__logo {
  height: 52px;
  width: auto;
  display: block;
}

.footer__nav {
  display: flex;
  align-items: center;
  list-style: none;
  gap: 0;
  margin: 0 auto;
}

.footer__nav-link {
  display: block;
  padding: 0 16px;
  font-size: 14px;
  font-weight: 500;
  color: rgba(255,255,255,0.7);
  white-space: nowrap;
  transition: color 0.2s;
}

.footer__nav-link:hover { color: #fff; }

.footer__contact {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4px;
  flex-shrink: 0;
}

.footer__contact-item {
  display: flex;
  align-items: center;
  gap: 7px;
  color: rgba(255,255,255,0.7);
  font-size: 12.5px;
  direction: rtl;
  transition: color 0.2s;
}

.footer__contact-item:hover { color: #fff; }
.footer__contact-item svg { color: var(--color-teal-mid); flex-shrink: 0; }

.footer__bottom {
  padding: 12px 0;
}

.footer__copy {
  font-size: 12px;
  color: rgba(255,255,255,0.35);
  text-align: center;
}

@media (max-width: 900px) {
  .footer__inner {
    height: auto;
    padding: 20px 0;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }
  .footer__nav {
    order: 2;
    flex-wrap: wrap;
    justify-content: center;
  }
  .footer__contact {
    order: 3;
    align-items: center;
  }
}
</style>
