---
const footerLinks = [
  { label: 'בית', href: '#hero' },
  { label: 'מי אנחנו', href: '#about' },
  { label: 'שירותי גיוס', href: '#services-2' },
  { label: 'ניהול מבנים', href: '#services-3' },
  { label: 'דרושים', href: '#jobs' },
  { label: 'צור קשר', href: '#contact' },
];
---

<footer class="footer">
  <div class="footer__main">
    <div class="container footer__grid">
      <div class="footer__brand">
        <img src="/logos/VEGA-LOGO-white.png" alt="VEGA Holdings" class="footer__logo" />
        <p class="footer__tagline">אנשים טובים, תמצאות מצויינות</p>
        <p class="footer__since">מאז 1989 – 35+ שנות ניסיון</p>
        <div class="footer__social">
          <a href="#" aria-label="Facebook" class="footer__social-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a>
          <a href="#" aria-label="LinkedIn" class="footer__social-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>
          </a>
          <a href="#" aria-label="Instagram" class="footer__social-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </a>
        </div>
      </div>

      <div class="footer__col">
        <h4 class="footer__col-title">ניווט</h4>
        <ul class="footer__nav">
          {footerLinks.map(link => (
            <li><a href={link.href} class="footer__nav-link">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <div class="footer__col">
        <h4 class="footer__col-title">שירותים</h4>
        <ul class="footer__nav">
          <li><a href="#services-1" class="footer__nav-link">גיוס עובדים</a></li>
          <li><a href="#services-2" class="footer__nav-link">השמה מקצועית</a></li>
          <li><a href="#services-3" class="footer__nav-link">ניהול מבנים</a></li>
          <li><a href="#services-3" class="footer__nav-link">תחזוקה שוטפת</a></li>
          <li><a href="#jobs" class="footer__nav-link">לוח משרות</a></li>
        </ul>
      </div>

      <div class="footer__col">
        <h4 class="footer__col-title">צור קשר</h4>
        <div class="footer__contact">
          <a href="tel:050-000-0000" class="footer__contact-item">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 9.12a16 16 0 0 0 6 6l1.48-1.48a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16z"/></svg>
            050-000-0000
          </a>
          <a href="mailto:info@vega-il.co.il" class="footer__contact-item">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            info@vega-il.co.il
          </a>
          <span class="footer__contact-item">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            רח' הרצל 1, תל אביב
          </span>
        </div>
      </div>
    </div>
  </div>

  <div class="footer__bottom">
    <div class="container footer__bottom-inner">
      <p class="footer__copy">© {new Date().getFullYear()} VEGA Holdings. כל הזכויות שמורות.</p>
      <div class="footer__legal">
        <a href="#">מדיניות פרטיות</a>
        <span>|</span>
        <a href="#">תנאי שימוש</a>
        <span>|</span>
        <a href="#">נגישות</a>
      </div>
    </div>
  </div>
</footer>

<style>
.footer {
  background: var(--color-dark);
  color: rgba(255,255,255,0.75);
}
.footer__main { padding: 64px 0 48px; }
.footer__grid {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1.5fr;
  gap: 48px;
}
.footer__logo {
  height: 60px;
  width: auto;
  display: block;
  margin-bottom: 12px;
}
.footer__tagline {
  font-family: var(--font-condensed);
  font-size: 16px;
  font-weight: 700;
  color: var(--color-white);
  margin-bottom: 4px;
}
.footer__since {
  font-size: 13px;
  color: rgba(255,255,255,0.5);
  margin-bottom: 20px;
}
.footer__social {
  display: flex;
  gap: 12px;
}
.footer__social-link {
  color: rgba(255,255,255,0.6);
  display: flex;
  align-items: center;
  transition: color 0.2s;
}
.footer__social-link:hover { color: var(--color-teal-mid); }

.footer__col-title {
  font-family: var(--font-condensed);
  font-size: 15px;
  font-weight: 700;
  color: var(--color-white);
  margin-bottom: 16px;
  letter-spacing: 0.5px;
}
.footer__nav {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 10px;
}
.footer__nav-link {
  font-size: 14px;
  color: rgba(255,255,255,0.65);
  transition: color 0.2s;
}
.footer__nav-link:hover { color: var(--color-teal-mid); }

.footer__contact {
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.footer__contact-item {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 14px;
  color: rgba(255,255,255,0.65);
  transition: color 0.2s;
}
.footer__contact-item svg { color: var(--color-teal-mid); flex-shrink: 0; }
.footer__contact-item:hover { color: var(--color-white); }

.footer__bottom {
  border-top: 1px solid rgba(255,255,255,0.1);
  padding: 18px 0;
}
.footer__bottom-inner {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 10px;
}
.footer__copy { font-size: 13px; color: rgba(255,255,255,0.4); }
.footer__legal {
  display: flex;
  gap: 10px;
  align-items: center;
  font-size: 13px;
  color: rgba(255,255,255,0.4);
}
.footer__legal a {
  color: rgba(255,255,255,0.5);
  transition: color 0.2s;
}
.footer__legal a:hover { color: var(--color-teal-mid); }

@media (max-width: 900px) {
  .footer__grid { grid-template-columns: 1fr 1fr; }
  .footer__brand { grid-column: 1 / -1; }
}
@media (max-width: 500px) {
  .footer__grid { grid-template-columns: 1fr; }
  .footer__bottom-inner { flex-direction: column; text-align: center; }
}
</style>
