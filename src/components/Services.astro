---
const services = [
  {
    num: '01',
    title: 'כוח אדם:',
    subtitle: 'גיוס מדויק לצורכי הלקוח',
    intro: 'אנחנו לא רק מאיישים משרה, אנחנו יוצרים יציבות.\nאנחנו מתמחים במציאת האנשים הנכונים למגוון רחב של תחומים.',
    bullets: [
      { label: 'תחומי התמחות:', text: 'מלונאות, מסחר וקמעונאות, לוגיסטיקה והפצה, תעשייה, מגזר ציבורי, בידור, חינוך ושירות.' },
      { label: 'התאמה מלאה:', text: 'תהליך הגיוס שלנו כולל אפיון צרכים מדויק וליווי מקצועי עד לקליטה מלאה בארגון.' },
      { label: 'גמישות תפעולית:', text: 'מתן מענה מהיר לצרכים משתנים, כי עם נוכחות בכל רחבי הארץ וניסיון של עשרות שנים בשטח, אנחנו שם כשצריך. בלי עיכובים ובלי תירוצים.' },
    ],
    img1: { src: 'https://images.unsplash.com/photo-1560347876-aeef00ee58a1?w=400&q=80', alt: 'לובי מלון' },
    img2: { src: 'https://images.unsplash.com/photo-1600880292203-757bb62b4baf?w=600&q=80', alt: 'צוות מקצועי' },
  },
  {
    num: '02',
    title: 'שירותי ניקיון:',
    subtitle: 'סטנדרט גבוה, יום אחרי יום',
    intro: 'ניקיון הוא לא רק "להעביר סמרטוט". הוא הרושם הראשוני שלכם.',
    bullets: [
      { label: 'עבודות שוטפות:', text: 'החל מניקיון משרדים יומיומי ובתי מלון ועד ניקיון בבתי ספר ומוסדות ציבור.' },
      { label: 'עבודות מיוחדות:', text: 'עבודות מורכבות כמו פוליש, אוסמוזה, ניקוי חניונים או ניקיון יסודי אחרי שיפוץ.' },
      { label: 'עבודה בגובה:', text: 'צוותי סנפלינג מוסמכים לניקוי חלונות ומעטפת המבנה.' },
    ],
    img1: null,
    img2: { src: '/images/cleaning-worker.jpg', alt: 'עובד ניקיון בחניון' },
  },
  {
    num: '03',
    title: 'ניהול ואחזקת מבנים:',
    subtitle: 'אחריות מלאה ושקט תפעולי',
    intro: 'אנחנו מספקים מעטפת תחזוקה כוללת למשרדים,\nמוסדות ונכסים מניבים. במקום שתתרוצצו בין ספקים,\nאנחנו מרכזים את הכל תחת ניהול אחד.',
    bullets: [
      { label: 'תחזוקה שוטפת:', text: 'טיפול במערכות המבנה, ניהול בעלי מקצוע ופיקוח צמוד.' },
      { label: 'ניהול פרויקטים:', text: 'תיאום ובקרה על פרויקטים מורכבים תוך עמידה בלוחות זמנים ובתקציב.' },
      { label: 'צוות קבוע:', text: 'לכל פרויקט מוצמד מנהל אחזקה שמכיר את הנכס לעומק ודואג לתפקוד תקין ושמירה על ערך המבנה.' },
    ],
    img1: { src: 'https://images.unsplash.com/photo-1486325212027-8081e485255e?w=400&q=80', alt: 'ניהול מבנים' },
    img2: { src: 'https://images.unsplash.com/photo-1581578731548-c64695cc6952?w=600&q=80', alt: 'תחזוקת מתקנים' },
  },
];
---

<section class="svc" id="services">

  <!-- ── Section title band ─────────────────────────── -->
  <div class="svc__header">
    <h2 class="svc__header-title">תחומי פעילות שלנו</h2>
  </div>

  <!-- ── Stacked service blocks ────────────────────── -->
  <div class="svc__body">
    {services.map((s, idx) => (
      <div class={`svc__item${idx % 2 === 1 ? ' svc__item--alt' : ''}`}>
        <div class="container svc__inner">

          <!-- Text content — first in DOM = right side in RTL -->
          <div class="svc__content">

            <div class="svc__head">
              <span class="svc__num" aria-hidden="true">{s.num}</span>
              <div class="svc__title-group">
                <h3 class="svc__title">{s.title}</h3>
                <p class="svc__subtitle">{s.subtitle}</p>
              </div>
            </div>

            <p class="svc__intro">{s.intro}</p>
            <div class="svc__rule"></div>

            <ul class="svc__bullets">
              {s.bullets.map(b => (
                <li class="svc__bullet">
                  <strong>{b.label}</strong>{' '}{b.text}
                </li>
              ))}
            </ul>

            <div class="svc__actions">
              <a href="#jobs" class="svc__btn svc__btn--primary">דרושים</a>
              <a href="#contact" class="svc__btn svc__btn--outline">יצירת קשר</a>
            </div>

          </div>

          <!-- Images — second in DOM = left side in RTL -->
          <div class={`svc__media${!s.img1 ? ' svc__media--single' : ''}`}>
            {s.img1 && (
              <div class="svc__img-a">
                <img src={s.img1.src} alt={s.img1.alt} loading="lazy" />
              </div>
            )}
            <div class="svc__img-b">
              <img src={s.img2.src} alt={s.img2.alt} loading="lazy" />
            </div>
          </div>

        </div>
      </div>
    ))}
  </div>

</section>

<style>
  /* ── Section wrapper ─────────────────────────────── */
  .svc {
    font-family: 'Assistant', 'Open Sans', sans-serif;
  }

  /* ── Header band ─────────────────────────────────── */
  .svc__header {
    background: var(--color-teal-mid);
    padding: 26px 24px;
    text-align: center;
  }
  .svc__header-title {
    font-family: 'Assistant', sans-serif;
    font-size: clamp(26px, 3.5vw, 42px);
    font-weight: 700;
    color: var(--color-dark);
    letter-spacing: -0.3px;
  }

  /* ── Body / background ───────────────────────────── */
  .svc__body {
    background: #f5f3ef;
  }

  /* ── Each service block ──────────────────────────── */
  .svc__item {
    background: #f5f3ef;
    border-top: 1px solid var(--color-teal-light);
  }
  .svc__item:first-child { border-top: none; }

  /* Alternate: cooler tint + flip layout */
  .svc__item--alt {
    background: #edf0ee;
  }
  .svc__item--alt .svc__num {
    color: var(--color-teal-mid);
  }
  .svc__item--alt .svc__inner {
    /* In RTL, row-reverse = content moves to left, media to right */
    flex-direction: row-reverse;
  }

  /* ── Inner layout ────────────────────────────────── */
  .svc__inner {
    display: flex;
    align-items: center;
    gap: 56px;
    padding-top: 64px;
    padding-bottom: 64px;
    /* RTL: svc__content (first) → right, svc__media (second) → left */
  }

  /* ── Content (right in RTL) ──────────────────────── */
  .svc__content {
    flex: 1 1 0;
    min-width: 0;
  }

  /* Numbered heading row — num + title grouped at RTL start (right) */
  .svc__head {
    display: flex;
    align-items: flex-start;
    justify-content: flex-start;
    gap: 16px;
    margin-bottom: 18px;
  }
  .svc__title-group {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
  .svc__title {
    font-family: 'Assistant', sans-serif;
    font-size: clamp(28px, 3.2vw, 40px);
    font-weight: 900;
    color: var(--color-dark);
    line-height: 1.1;
  }
  .svc__subtitle {
    font-family: 'Assistant', sans-serif;
    font-size: clamp(17px, 2vw, 22px);
    font-weight: 600;
    color: var(--color-teal-dark);
    line-height: 1.3;
  }
  .svc__num {
    font-family: 'Assistant', sans-serif;
    font-size: clamp(68px, 7.5vw, 96px);
    font-weight: 800;
    color: var(--color-teal-light);
    line-height: 0.8;
    flex-shrink: 0;
    user-select: none;
    letter-spacing: -3px;
    /* Nudge up so baseline aligns with title top */
    margin-top: -8px;
  }

  /* Intro text */
  .svc__intro {
    font-family: 'Assistant', sans-serif;
    font-size: 17px;
    line-height: 1.8;
    color: #555;
    white-space: pre-line;
    margin-bottom: 20px;
  }

  /* Teal rule */
  .svc__rule {
    height: 5px;
    background: var(--color-teal-dark);
    border-radius: 2px;
    margin-bottom: 22px;
  }

  /* Bullet list */
  .svc__bullets {
    list-style: disc;
    padding-inline-start: 22px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 32px;
  }
  .svc__bullet {
    font-family: 'Assistant', sans-serif;
    font-size: 16px;
    line-height: 1.75;
    color: #444;
  }
  .svc__bullet strong {
    font-weight: 800;
    color: var(--color-dark);
  }

  /* CTA buttons */
  .svc__actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
  .svc__btn {
    display: inline-block;
    padding: 10px 28px;
    border-radius: 4px;
    font-family: 'Assistant', sans-serif;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
    text-decoration: none;
    border: 2px solid transparent;
  }
  .svc__btn--primary {
    background: var(--color-dark);
    color: #fff;
    border-color: var(--color-dark);
  }
  .svc__btn--primary:hover {
    background: var(--color-teal-dark);
    border-color: var(--color-teal-dark);
  }
  .svc__btn--outline {
    background: transparent;
    color: var(--color-dark);
    border-color: var(--color-dark);
  }
  .svc__btn--outline:hover {
    background: var(--color-dark);
    color: #fff;
  }

  /* ── Media (left in RTL) ─────────────────────────── */
  .svc__media {
    flex: 0 0 43%;
    display: flex;
    gap: 10px;
    align-items: stretch;
    height: 370px;
  }
  .svc__img-a,
  .svc__img-b {
    border-radius: 10px;
    overflow: hidden;
    flex-shrink: 0;
  }
  .svc__img-a { flex: 0 0 36%; }
  .svc__img-b { flex: 1 1 0; }
  .svc__media--single .svc__img-b { flex: 1 1 100%; }
  .svc__media--single .svc__img-b img { object-position: top center; }
  .svc__img-a img,
  .svc__img-b img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ── Pagination ──────────────────────────────────── */
  .svc__pagination {
    display: flex;
    justify-content: center;
    gap: 8px;
    padding-top: 8px;
  }

  /* ── Responsive ──────────────────────────────────── */
  @media (max-width: 900px) {
    .svc__inner,
    .svc__item--alt .svc__inner {
      flex-direction: column;
      gap: 32px;
      padding-top: 40px;
      padding-bottom: 40px;
    }
    .svc__media {
      flex: none;
      width: 100%;
      height: 240px;
      order: -1;
    }
    .svc__media--single {
      height: 320px;
    }
    .svc__content { width: 100%; }
    .svc__num { font-size: 60px; }
  }
</style>
