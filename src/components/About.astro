---
const cards = [
  { img: '/icons/card-award.png',     alt: 'מעל 25 שנות ניסיון' },
  { img: '/icons/card-location.png',  alt: 'פריסה ארצית ומעל 1000 עובדים' },
  { img: '/icons/card-stopwatch.png', alt: 'זמינות גבוהה ומהירות תגובה' },
  { img: '/icons/card-handshake.png', alt: 'יחס אישי ושותפות עם הלקוח' },
  { img: '/icons/card-clipboard.png', alt: 'ניסיון מוכח בניהול פרויקטים מורכבים' },
  { img: '/icons/card-shield.png',    alt: 'ניהול מסודר ושקיפות מלאה' },
];
---

<section class="about" id="about">
  <div class="container">
    <!-- Centered logo block -->
    <div class="about__brand">
      <img src="/logos/VEGA-LOGO-SIMPLE.png" alt="VEGA Holdings" class="about__brand-logo" />
      <p class="about__brand-tagline">אנחנו שירות שחושב קדימה.</p>
      <p class="about__brand-body">
        <strong>VEGA HOLDINGS</strong> היא חברת שירותים ארצית המתמחה בכוח אדם, ניקיון ואחזקה וניהול מבנים.<br />
        מאז שנת 2000, אנחנו מלווים לקוחות מהמגזר המוסדי, הציבורי והפרטי, ומנהלים עבורם פרויקטים מורכבים בפריסה ארצית.<br />
        <strong>העבודה שלנו מבוססת על שלושה עקרונות:</strong> זמינות גבוהה, שקיפות מלאה ושמירה על זכויות העובדים ורווחתם.<br />
        <strong>המטרה שלנו פשוטה:</strong> לתת לכם שקט תפעולי לאורך זמן.
      </p>
      <a href="#contact" class="about__readmore">צור קשר</a>
    </div>

    <!-- Why section -->
    <h2 class="about__why-title">
      <span class="about__why-why">למה</span> VEGA HOLDINGS?
    </h2>

    <!-- Feature cards grid -->
    <div class="about__cards">
      {cards.map(card => (
        <div class="about__card-wrap">
          <img src={card.img} alt={card.alt} class="about__card-img" loading="lazy" />
        </div>
      ))}
    </div>
  </div>
</section>

<style>
.about {
  padding: 80px 0 88px;
  background: #f2f2f0;
}

/* Brand block */
.about__brand {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  max-width: 760px;
  margin: 0 auto 68px;
}
.about__brand-logo {
  height: 140px;
  width: auto;
  display: block;
  margin-bottom: 20px;
}
.about__brand-tagline {
  font-family: var(--font-condensed);
  font-size: 28px;
  font-weight: 700;
  color: var(--color-dark);
  margin-bottom: 22px;
}
.about__brand-body {
  font-size: 17px;
  line-height: 2;
  color: #444;
  margin-bottom: 32px;
  text-align: center;
}
.about__brand-body strong {
  color: var(--color-teal-dark);
}
.about__readmore {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: var(--color-teal-mid);
  color: #fff;
  font-size: 15px;
  font-weight: 600;
  padding: 13px 52px;
  border-radius: 40px;
  transition: background 0.2s;
}
.about__readmore:hover { background: var(--color-teal-dark); }

/* Why heading */
.about__why-title {
  font-family: var(--font-condensed);
  font-size: clamp(28px, 4vw, 42px);
  font-weight: 700;
  color: var(--color-dark);
  text-align: center;
  margin-bottom: 40px;
  line-height: 1.15;
}
.about__why-why {
  color: var(--color-teal-mid);
}

/* Feature cards — PNGs are pre-designed cards with ~25% transparent padding
   top and bottom. Wrapper clips that padding so cards sit flush in the grid. */
.about__cards {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0;
  max-width: 960px;
  margin: 0 auto;
}
/* overflow:hidden clips the transparent PNG padding above/below the white card */
.about__card-wrap {
  overflow: hidden;
}
.about__card-img {
  width: 100%;
  height: auto;
  display: block;
  /* PNG is 1080×1350 (aspect 1.25). Shadow occupies top=24.9%→31.9% and
     bottom=32.5%→25.6% of image height. We crop deep into the shadow to
     keep cards compact. margin% is relative to parent width, so × 1.25:
     target crop ≈ 35% of parent width clips most shadow, leaves a sliver. */
  margin-top: -35%;
  margin-bottom: -35%;
  transition: transform 0.2s;
}
.about__card-img:hover {
  transform: scale(1.04);
}

@media (max-width: 768px) {
  .about__cards { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 480px) {
  .about__cards { grid-template-columns: 1fr; }
}
</style>
